{
  "name": "bibliary",
  "version": "2.3.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "description": "Vector knowledge store — natural language concepts for site generation",
  "scripts": {
    "init": "tsx src/init-collection.ts",
    "load": "tsx src/load.ts",
    "search": "tsx src/search.ts",
    "llm": "tsx src/llm-prompt.ts",
    "chat": "tsx src/rag-chat.ts",
    "export": "tsx scripts/export-all.ts",
    "duplicates": "tsx scripts/find-duplicates.ts",
    "inventory": "tsx scripts/inventory.ts",
    "validate-batch": "tsx scripts/validate-batch.ts",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "node scripts/prepare-electron.js && tsc -p tsconfig.electron.json && electron dist-electron/main.js",
    "electron:build": "node scripts/prepare-electron.js && tsc -p tsconfig.electron.json && electron-builder",
    "electron:build-portable": "node scripts/prepare-electron.js && tsc -p tsconfig.electron.json && node scripts/build-portable.js && node scripts/copy-portable-dist.js",
    "test:scanner": "tsx scripts/test-scanner.ts",
    "test:e2e:scanner": "tsx scripts/e2e-book-ingest.ts",
    "test:e2e:library-ux": "tsx scripts/e2e-library-ux.ts",
    "test:dataset-v2": "tsx scripts/test-dataset-v2.ts",
    "test:model-select": "tsx scripts/test-model-select.ts",
    "test:bookhunter": "tsx scripts/test-bookhunter.ts",
    "test:agent-live": "tsx scripts/test-agent-live.ts",
    "test:dataset-v2-live": "tsx scripts/test-dataset-v2-live.ts",
    "test:e2e:mvp": "tsx scripts/e2e-full-mvp.ts",
    "test:e2e:quality": "tsx scripts/e2e-quality.ts",
    "lint": "tsc -p tsconfig.electron.json --noEmit && eslint \"renderer/**/*.js\" --ignore-pattern \"renderer/vendor/**\" --max-warnings=0",
    "lint:fix": "eslint \"renderer/**/*.js\" --ignore-pattern \"renderer/vendor/**\" --fix"
  },
  "dependencies": {
    "@lmstudio/sdk": "^1.5.0",
    "@napi-rs/canvas": "^0.1.99",
    "@napi-rs/system-ocr": "^1.0.2",
    "@qdrant/js-client-rest": "^1.12.0",
    "@xenova/transformers": "^2.17.2",
    "dompurify": "^3.4.1",
    "dotenv": "^16.4.7",
    "fast-xml-parser": "^4.5.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "marked": "^18.0.0",
    "pdfjs-dist": "^4.10.38",
    "proper-lockfile": "^4.1.2",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/uuid": "^10.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}

{
  "name": "bibliary",
  "version": "2.0.1",
  "type": "module",
  "main": "dist-electron/main.js",
  "description": "Local book library → structured Markdown → embedded LanceDB vector collections → ChatML JSONL fine-tuning datasets",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "inventory": "tsx scripts/inventory.ts",
    "validate-batch": "tsx scripts/validate-batch.ts",
    "postinstall": "node scripts/postinstall.cjs",
    "dev:server": "tsx watch server/main.ts",
    "dev:web": "vite",
    "dev": "concurrently -k -n server,web -c blue,magenta npm:dev:server npm:dev:web",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "vite build",
    "build": "npm run build:server && npm run build:web",
    "start": "node dist-server/server/main.js",
    "appwrite:bootstrap": "tsx scripts/appwrite-bootstrap.ts",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "electron:clean": "node --input-type=commonjs -e \"try{require('fs').rmSync('dist-electron',{recursive:true,force:true})}catch{}\"",
    "electron:compile": "npm run electron:clean && tsc -p tsconfig.electron.json && node scripts/prepare-electron.js",
    "electron:dev": "node scripts/ensure-sqlite-abi.cjs --target=electron && npm run electron:compile && electron dist-electron/main.js",
    "sqlite:select-node": "node scripts/ensure-sqlite-abi.cjs --target=node",
    "sqlite:select-electron": "node scripts/ensure-sqlite-abi.cjs --target=electron",
    "sqlite:save-node": "node scripts/ensure-sqlite-abi.cjs --save --target=node",
    "sqlite:save-electron": "node scripts/ensure-sqlite-abi.cjs --save --target=electron",
    "sqlite:rebuild-electron": "node scripts/ensure-sqlite-abi.cjs --target=electron",
    "verify:deps-for-packaging": "node scripts/verify-deps-for-packaging.cjs",
    "electron:build": "npm run verify:deps-for-packaging && npm run electron:compile && electron-builder",
    "electron:build-portable": "npm run verify:deps-for-packaging && npm run electron:compile && node scripts/build-portable.js && node scripts/copy-portable-dist.js",
    "doctor": "node scripts/doctor.cjs",
    "icon:generate": "node scripts/generate-icon.cjs",
    "test:scanner": "tsx scripts/test-scanner.ts",
    "test:dataset-v2": "tsx scripts/test-dataset-v2.ts",
    "test:model-select": "tsx scripts/test-model-select.ts",
    "test:e2e:bibliarifull": "tsx scripts/e2e-bibliarifull-library-import.ts",
    "test:e2e:bibliarifull-bundle": "tsx scripts/e2e-bibliarifull-bundle-import.ts",
    "test:e2e:full-corpus": "tsx scripts/e2e-full-corpus-library-import.ts",
    "test:e2e:1000-electron": "node scripts/run-electron-node.cjs scripts/e2e-1000-random-sample.ts",
    "dataset:synth": "tsx scripts/dataset-synth.ts",
    "dataset:probe-model": "tsx scripts/probe-evaluator-pick.ts",
    "test": "npm run test:rebuild-native && node --import tsx --test tests/*.test.ts",
    "test:unit": "npm run test:rebuild-native && node --import tsx --test tests/*.test.ts",
    "test:rebuild-native": "node scripts/ensure-sqlite-abi.cjs --target=node",
    "test:fast": "node --import tsx --test tests/*.test.ts",
    "test:fast:serial": "node --import tsx --test --test-concurrency=1 tests/*.test.ts",
    "test:smoke": "node scripts/prepare-electron.js && tsc -p tsconfig.electron.json && node --import tsx --test tests/smoke/*.test.ts",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit",
    "lint": "npm run typecheck && eslint \"renderer/**/*.js\" --ignore-pattern \"renderer/vendor/**\" --max-warnings=0",
    "lint:fix": "eslint \"renderer/**/*.js\" --ignore-pattern \"renderer/vendor/**\" --fix",
    "dead-code": "knip --no-progress",
    "prepare": "husky",
    "setup:djvulibre": "node scripts/download-djvulibre-win.cjs",
    "setup:7zip": "node scripts/download-7zip-win.cjs",
    "setup:tessdata": "node scripts/download-tessdata.cjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@firecrawl/pdf-inspector": "^1.8.0",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.0",
    "@lancedb/lancedb": "^0.21.3",
    "@lmstudio/sdk": "^1.5.0",
    "@napi-rs/canvas": "^0.1.99",
    "@napi-rs/system-ocr": "^1.0.2",
    "@xenova/transformers": "^2.17.2",
    "7z-bin": "^0.0.8",
    "7zip-bin": "^5.2.0",
    "apache-arrow": "^17.0.0",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.9.0",
    "chardet": "^2.1.1",
    "edgeparse": "^0.2.3",
    "fast-xml-parser": "^4.5.1",
    "fastest-levenshtein": "^1.0.16",
    "hono": "^4.6.0",
    "iconv-lite": "^0.7.2",
    "jose": "^5.9.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "marked": "^18.0.0",
    "node-appwrite": "^15.0.0",
    "openai": "^4.70.0",
    "p-queue": "^8.0.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "proper-lockfile": "^4.1.2",
    "sharp": "^0.32.0",
    "sqlite-vec": "^0.1.6",
    "tesseract.js": "^7.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.0",
    "@types/proper-lockfile": "^4.1.4",
    "concurrently": "^9.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "knip": "^5.88.1",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}

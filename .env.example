# =================================================================
# Bibliary — self-hosted web service. Copy to .env and fill in.
# Runs on SQLite + the local filesystem; no external database.
# =================================================================

# --- Server runtime ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# --- Data dir ---
# Holds the SQLite databases (documents + vectors), uploaded files,
# and the embedding model cache.
BIBLIARY_DATA_DIR=./data
# Optional: override the document DB path (defaults to
# $BIBLIARY_DATA_DIR/bibliary.db). Mainly useful for tests.
# BIBLIARY_DB_PATH=

# --- JWT (RS256) ---
# Generate with:
#   openssl genpkey -algorithm RSA -out jwt-private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
# Then paste contents here. Multi-line PEMs must escape newlines as \n
# (or use a .env loader that supports multi-line values).
# Required when NODE_ENV=production.
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# --- Crypto ---
# 32+ char random string for AES-256-GCM on per-user provider API keys.
# Generate with: openssl rand -hex 32
# Required when NODE_ENV=production.
BIBLIARY_ENCRYPTION_KEY=

# --- Optional admin bootstrap ---
# Comma-separated emails that get role=admin on signup.
# The first user to register becomes admin regardless of this list.
BIBLIARY_ADMIN_EMAILS=

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Cookies ---
# Set COOKIE_SECURE=true in production behind HTTPS.
COOKIE_SECURE=false
COOKIE_DOMAIN=

# --- Upload limits ---
# Multipart upload size cap (bytes). Hono buffers the whole body in
# RAM, so cap to a sane size to prevent OOM on a modest-server pod.
# Default: 200 MB. Tune up for giant scanned PDFs.
BIBLIARY_UPLOAD_MAX_BYTES=209715200

# --- Public registration ---
# After the first admin is seeded, set true to refuse /register with
# 403. Existing users keep working.
BIBLIARY_REGISTRATION_DISABLED=false

# --- LLM ---
# Point at an LM Studio instance, or leave it and configure
# Anthropic / OpenAI keys per-user in Settings -> Providers.
LM_STUDIO_URL=http://localhost:1234

# Optional: Google Books API key for ISBN-based metadata lookups.
BIBLIARY_GOOGLE_BOOKS_API_KEY=

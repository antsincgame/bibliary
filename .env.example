# =================================================================
# Bibliary web backend (Hono + Appwrite) — copy to .env and fill in.
# =================================================================

# --- Server runtime ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# --- Appwrite ---
# After `docker compose -f docker-compose.dev.yml up -d`, visit
# http://localhost/console, create a project, then an API key with
# `databases.*` and `storage.*` scopes. Paste them here.
APPWRITE_ENDPOINT=http://localhost/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=bibliary

# --- JWT (RS256) ---
# Generate with:
#   openssl genpkey -algorithm RSA -out jwt-private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
# Then paste contents here. Multi-line PEMs must escape newlines as \n
# (or use a .env loader that supports multi-line values).
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# --- Crypto ---
# 32+ char random string for AES-256-GCM on per-user provider API keys.
# Generate with: openssl rand -hex 32
BIBLIARY_ENCRYPTION_KEY=

# --- Optional admin bootstrap ---
# Comma-separated emails that get role=admin on signup.
# The first user to register becomes admin regardless of this list.
BIBLIARY_ADMIN_EMAILS=

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Cookies ---
# Set COOKIE_SECURE=true in production behind HTTPS.
COOKIE_SECURE=false
COOKIE_DOMAIN=

# --- Data dir ---
# Holds sqlite-vec database and other backend-only state.
BIBLIARY_DATA_DIR=./data

# --- Upload limits ---
# Multipart upload size cap (bytes). Hono buffers the whole body in
# RAM, so cap to a sane size to prevent OOM on a modest-server pod.
# Default: 200 MB. Tune up for giant scanned PDFs.
BIBLIARY_UPLOAD_MAX_BYTES=209715200

# --- Public registration ---
# After the first admin is seeded, set true to refuse /register with
# 403. Existing users keep working.
BIBLIARY_REGISTRATION_DISABLED=false

# =================================================================
# docker-compose.prod.yml only
# =================================================================
# Domain Appwrite advertises to itself (and OAuth callbacks). Use the
# host you'll reach from a browser: "localhost" locally, real FQDN
# in production.
APPWRITE_DOMAIN=localhost
APPWRITE_EMAIL=admin@localhost

# MariaDB credentials — keep behind container network, change for
# production.
MARIADB_PASSWORD=password
MARIADB_ROOT_PASSWORD=rootsecret

# =================================================================
# Legacy Electron build (still works until Phase 12)
# =================================================================
LM_STUDIO_URL=http://localhost:1234

# Optional: Google Books API key for ISBN-based metadata lookups.
BIBLIARY_GOOGLE_BOOKS_API_KEY=

# E2E UI testing only — set to "1" to return fake smoke data from IPC.
BIBLIARY_SMOKE_UI_HARNESS=

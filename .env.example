QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=concepts
LM_STUDIO_URL=http://localhost:1234

# Optional: Google Books API key for ISBN-based metadata lookups (Open Library works without a key).
# Get a free key at https://console.cloud.google.com/ → Books API
BIBLIARY_GOOGLE_BOOKS_API_KEY=

# ONLY for automated E2E UI testing. When set to "1" the library IPC namespace returns
# fake smoke data (smoke-book-a, smoke-book-b, etc.) instead of calling real IPC handlers.
# NEVER set this in production — all library operations will silently return stub data.
BIBLIARY_SMOKE_UI_HARNESS=

node_modules/
dist/
dist-electron/
dist-renderer/
dist-server/
release/
.env
.cache/
*.blockmap

# Portable build artifacts (output to project root)
Bibliary*.exe
Bibliary*.blockmap

# IDE / AI local config — ignore everything inside .claude/ EXCEPT rules/
.claude/*
!.claude/rules/
.git-commit-msg.tmp
.commit-msg

# Debug diagnostic artifacts
_*.json

# Source texts (copyrighted books — not for redistribution)
data/*.pdf
data/*.txt
*.txt

# Generated / intermediate data
data/_*
data/cleanup/
data/apps/

# Merge artifacts inside concepts
data/concepts/_*
data/concepts/merged-dedup.json

# Finetune workspace — игнор всего, кроме seed-данных
data/finetune/*
!data/finetune/README.md
!data/finetune/gold-examples.jsonl
!data/finetune/source-chunks.json

# Resilience layer (Phase 2.5R)
data/telemetry.jsonl
data/telemetry-*.jsonl
data/checkpoints/
data/prompts/

# Library v2 (Pre-flight Evaluation pipeline)
# Copyrighted books — never redistribute via git.
data/library/
data/bibliary-cache.db
data/bibliary-cache.db-wal
data/bibliary-cache.db-shm

# Web-mode sqlite-vec runtime state (server/lib/vectordb/db.ts opens
# BIBLIARY_VECTORS_DB_PATH or ./data/vectors.db). Per-pod runtime,
# never committed. WAL + SHM companion files included.
data/vectors.db
data/vectors.db-wal
data/vectors.db-shm

# HuggingFace ONNX model cache (server/lib/embedder/index.ts points
# TRANSFORMERS_CACHE at BIBLIARY_DATA_DIR/models). Auto-downloaded
# at first embed call (or via prewarm); never committed.
data/models/

# Converter output cache (EPUB/PDF/TXT artifacts; не для VCS)
data/converters-cache/

# Servitor quarantine (recoverable docs/code trash)
.servitor-trash/

# Library reset backups (raw books, never push)
data/_library-reset-backup-*/

# User-local preferences (model choices, etc.)
data/preferences.json

# Rebuild / native-module stash
.electron-rebuild-stash/

# Temporary native-build artifacts (когда экспериментируем с компиляцией Rust-крейтов
# вручную — финальный pdf-inspector подключаем как готовый npm-пакет с prebuilt binary)
build-temp/
test_rust.rs

# DjVuLibre downloaded installers (not needed in repo)
vendor/djvulibre/**/*_Setup.exe

# macOS vendor binaries — устанавливаются `setup:djvulibre-macos` /
# `setup:7zip-macos` через Homebrew перед сборкой. Windows vendors
# зафиксированы в репо для воспроизводимой portable-сборки без brew.
vendor/djvulibre/darwin-x64/
vendor/djvulibre/darwin-arm64/
vendor/7zip/darwin-x64/
vendor/7zip/darwin-arm64/

# Benchmark and E2E reports (generated data, not for VCS)
data/benchmarks/
data/e2e-reports/

# Import audit logs
data/logs/

# v1.0.7: structured LM Studio actions log (in userData OR project root from tests)
logs/
data/lmstudio-actions.log

# Olympics report — runtime artifact (не для VCS)
data/olympics-report.json

# Tesseract.js traineddata orphans at repo root (если случайно скачались
# не в vendor/tessdata/). Реальные модели лежат в vendor/tessdata/*.traineddata
# и трекаются через extraResources в electron-builder.yml.
/*.traineddata
